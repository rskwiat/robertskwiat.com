{
  "extends": "airbnb",
  rules: {
      "comma-dangle": ["error", "never"],
      "react/jsx-filename-extension": [1,
        { "extensions": [".js", ".jsx"]
      }],
      "prefer-stateless-function": [ 0,
        { "ignorePureComponents": true
      }]
    },
  "env": {
    "browser": true,
    "node": true
  }
}
