{
  "name": "robertskwiat.com",
  "version": "1.0.0",
  "description": "## Isomorphic React + Express",
  "main": "index.js",
  "dependencies": {
    "babel": "^6.5.2",
    "babel-preset-es2015": "^6.5.0",
    "babel-preset-react": "^6.5.0",
    "babel-register": "^6.5.2",
    "body-parser": "^1.14.1",
    "cookie-parser": "^1.4.0",
    "ejs": "^2.4.1",
    "express": "^4.13.3",
    "history": "^2.0.0",
    "hogan-express": "^0.5.2",
    "react": "^15.0.1",
    "react-dom": "^15.0.1",
    "react-redux": "^4.4.0",
    "react-router": "^2.0.0",
    "redux": "^3.3.1",
    "underscore": "^1.8.3"
  },
  "scripts": {
    "copy": "rm -rf public/index.html && cp views/index.ejs public/index.html",
    "dev": "npm run copy && node ./node_modules/webpack-dev-server/bin/webpack-dev-server.js --hot --inline --devtool inline-source-map --history-api-fallback",
    "compile:js": "node ./node_modules/webpack/bin/webpack.js -p",
    "test": "NODE_ENV=test ./node_modules/.bin/webpack",
    "posttest": "open test/index.html",
    "compile:sass:dev": "node ./node_modules/node-sass/bin/node-sass -w public/scss/app.scss public/css/app.css",
    "compile:sass:production": "node ./node_modules/node-sass/bin/node-sass --output-style compressed public/scss/app.scss public/css/app.css",
    "preproduction": "npm run compile:sass:production && npm run compile:js",
    "production": "node app.js"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "babel-core": "^6.6.5",
    "babel-loader": "^6.2.4",
    "node-jsx": "^0.13.3",
    "node-sass": "^3.4.2",
    "static-server": "^2.0.1",
    "react-hot-loader": "1.3.0",
    "webpack": "^1.12.14",
    "webpack-dev-server": "^1.14.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rskwiat/robertskwiat.com.git"
  },
  "bugs": {
    "url": "https://github.com/rskwiat/robertskwiat.com/issues"
  },
  "homepage": "https://github.com/rskwiat/robertskwiat.com#readme"
}
