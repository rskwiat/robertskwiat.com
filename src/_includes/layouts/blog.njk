<!doctype html>
<html lang="en">
  {% include "components/head.njk" %}

  <body>
    <main>
      {% include "components/dark-mode.njk" %}

      <div class="container">
        <h1>{{ page.data.title }}</h1>

{% block content %}
	{% for post in collections.blog %}
		<h1>{{ post.data.title }}</h1>
		<a href={{ post.url }}>Read More</a>

	{% endfor %}
{% endblock %}

<h1>{{ title }}</h1>

<p>{{ description }}</p>
        {{ content | safe }}

        <p>Home | <a href="/blog/">Blog</a> | <a href="/about/">About</a></p>
        {% include "components/see-more.njk" %}
      </div>
      {% include "components/footer.njk" %}
    </main>
  </body>
  {% include "components/scripts.njk" %}

</html>
